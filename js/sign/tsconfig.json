{
  "compilerOptions": {
    "rootDir": "src",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "stripInternal": true,
    "declaration": true,
    "newLine": "lf",
    "outDir": "lib"
  },
  "include": ["src/**/*"]
}
